{
  "version": 2,
  "name": "chartreader-io",
  "builds": [
    { "src": "api/**/*.php", "use": "vercel-php@0.7.0" },
    { "src": "public/**/*", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "^/$", "dest": "/public/index.html" },
    { "src": "^/api/(.*)$", "dest": "/api/$1" },
    { "src": "^/(.*)$", "dest": "/public/$1" }
  ],
  "env": {
    "APP_ENV": "production",
    "DB_PATH": "/tmp/database.sqlite"
  }
}
